---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The requested Signal Protocol page could not be found.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>This route has no session.</h1>
      <p class="lead">The page may have moved, or the address may be incomplete.</p>
      <div class="button-row" style="margin-top: 2rem">
        <a class="button" href="/">Return home</a>
        <a class="button button-secondary" href="https://docs.signal-protocol.dev">Search the docs</a>
      </div>
    </div>
  </section>
</BaseLayout>
